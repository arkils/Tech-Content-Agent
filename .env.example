# =============================================================================
# tech-news-agent — local environment configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored — never commit it.
#
# Usage:
#   python scripts/run_local.py          # loads .env.local automatically
#
# AWS credentials are NOT set here — boto3 uses your ~/.aws/credentials file.
# Set AWS_PROFILE below if you need a non-default profile.
# =============================================================================

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------

# AWS region where your DynamoDB tables, Bedrock, and SSM parameters live.
AWS_REGION=us-east-1

# Optional: named profile from ~/.aws/credentials.
# Leave blank to use the [default] profile.
# AWS_PROFILE=my-profile

# ---------------------------------------------------------------------------
# DynamoDB table names
# These must match the table names deployed by the CDK StorageStack.
# ---------------------------------------------------------------------------
DYNAMODB_TABLE_NAME=tech-news-agent-articles
NEWS_FEEDS_TABLE=tech-news-agent-feeds
POSTS_TABLE_NAME=tech-news-agent-posts

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------

# Which LLM to use: "bedrock" (default) or "openai".
# "bedrock" tries Bedrock first and falls back to OpenAI on error.
# "openai"  skips Bedrock entirely and calls OpenAI directly.
LLM_PROVIDER=bedrock

# Bedrock model ID (only used when LLM_PROVIDER=bedrock).
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# OpenAI model ID — used when LLM_PROVIDER=openai OR as the Bedrock fallback.
# API key is fetched at runtime from SSM: /tech-news-agent/openai
OPENAI_MODEL_ID=gpt-4.1-mini

# ---------------------------------------------------------------------------
# Publisher
# ---------------------------------------------------------------------------

# Comma-separated list of enabled publishers.
# Supported values: linkedin  (blog / instagram / youtube are stubs)
ENABLED_PUBLISHERS=linkedin

# Master posting switch.
# false (default) — post is generated and saved to DynamoDB but NOT sent to LinkedIn.
# true            — post is actually delivered to the LinkedIn API.
ENABLE_POSTING=false

# ---------------------------------------------------------------------------
# Pipeline behaviour
# ---------------------------------------------------------------------------

# Maximum number of articles to fetch and process per run.
MAX_ARTICLES_PER_RUN=20

# How many days processed article URLs are retained in DynamoDB.
ARTICLE_TTL_DAYS=90

# How many days generated post records are retained in DynamoDB.
POST_TTL_DAYS=365

# Set to true to bypass deduplication and force the pipeline to re-process
# all fetched articles. Useful when all articles are already marked as seen
# and you want to test the full summarise → generate → publish flow locally.
FORCE_NO_NEW_ARTICLES=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
